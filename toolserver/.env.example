# ─────────────────────────────────────────────────────────────────────────────
# Xybernetex ToolServer — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Tavily Web Search ─────────────────────────────────────────────────────────
# Required for the web_search tool.
# Get your key at: https://app.tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend Email ─────────────────────────────────────────────────────────────
# Required for the send_email tool.
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default "from" address for outbound emails.
# Must be a verified domain in your Resend account.
# Can be overridden per-invocation via input.from
RESEND_FROM_ADDRESS=Xybernetex <noreply@xybernetex.com>

# ── Auth ──────────────────────────────────────────────────────────────────────
# HMAC-SHA256 signing secret shared with the Worker.
# Must match XYBER_TOOL_WEBHOOK_SECRET in your Worker .env.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
XYBER_TOOL_WEBHOOK_SECRET=change_me_generate_a_strong_secret

# ── Server ────────────────────────────────────────────────────────────────────
TOOL_SERVER_HOST=0.0.0.0
TOOL_SERVER_PORT=9000
LOG_LEVEL=info
