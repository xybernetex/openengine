# Xybernetex AI OpenEngine — .gitignore
# IMPORTANT: never commit model weights or .env files

# ── Python bytecode ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ── Environment / secrets ──────────────────────────────────────────────────────
.env
# .env.example is safe to commit — it contains no real secrets

# ── Model weights (NEVER commit — use GitHub Releases) ─────────────────────────
models/*.pt
models/*.bin
models/*.safetensors
models/*.ckpt

# ── Build / packaging ──────────────────────────────────────────────────────────
*.egg-info/
dist/
build/
*.egg
MANIFEST
*.whl

# ── Test & type-check caches ───────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ── Runtime output ─────────────────────────────────────────────────────────────
logs/
output/
*.log

# ── Databases ─────────────────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Node (docs tooling / n8n local) ───────────────────────────────────────────
node_modules/
package-lock.json
yarn.lock

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
