# Xybernetex AI OpenEngine — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — only .env.example is safe to commit.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Supported values: cloudflare | openai | mistral | anthropic | gemini
LLM_PROVIDER=cloudflare

# Model to use (leave blank to use the provider default).
# Cloudflare:  @cf/meta/llama-3.3-70b-instruct-fp8-fast
# OpenAI:      gpt-4o-mini
# Mistral:     mistral-small-latest
# Anthropic:   claude-3-5-haiku-20241022
# Gemini:      gemini-1.5-flash
LLM_MODEL=

# Shorthand alias used by inference_worker (llama | llama70b | mistral | qwen)
DEFAULT_MODEL=llama70b

# API key for the chosen provider.
# For Cloudflare, leave blank — use CF_API_TOKEN below instead.
LLM_API_KEY=

# Cloudflare Workers AI credentials (only required when LLM_PROVIDER=cloudflare)
CF_ACCOUNT_ID=
CF_API_TOKEN=

# ── Tool Server ───────────────────────────────────────────────────────────────
# URL of the ToolServer webhook endpoint.
# In local dev this is typically the FastAPI server running on port 9000.
XYBER_TOOL_WEBHOOK_URL=http://localhost:9000/invoke

# HMAC-SHA256 shared secret for signing webhook requests.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
XYBER_TOOL_WEBHOOK_SECRET=

# ── Capability manifest ───────────────────────────────────────────────────────
# Path to the JSON file that declares available tools and their schemas.
# Relative paths are resolved from the engine file's directory.
XYBER_CAPABILITY_MANIFEST_PATH=examples/manifests/toolserver.json
XYBER_CAPABILITY_MANIFEST_JSON=
XYBER_TOOLS_JSON=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — keep path OUTSIDE any cloud-synced folder to prevent
# WAL journal corruption from Dropbox / Google Drive sync processes):
DATABASE_URL=sqlite:///openengine.db
DATABASE_PATH=/var/lib/openengine/working_memory.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/openengine

# ── Redis (optional — for queue / production mode) ────────────────────────────
# Required only when running the engine as a Redis consumer (not needed for
# local single-run mode via `python inference_worker.py "<goal>"`).
REDIS_URL=redis://localhost:6379

# ── Telemetry — OVH Object Storage upload (optional) ─────────────────────────
# Set to "true" to enable background async upload.
# Requires boto3. The inference loop is never blocked — uploads run on a
# daemon thread. If boto3 is absent or any var below is missing, silently skipped.
OBJECT_STORAGE_UPLOAD=false
OVH_OS_ENDPOINT=https://s3.<region>.perf.cloud.ovh.net
OVH_OS_ACCESS_KEY=
OVH_OS_SECRET_KEY=
OVH_OS_BUCKET=openengine-runs

# ── Local dev ─────────────────────────────────────────────────────────────────
# User ID used when running goals locally (no auth layer).
XYBER_LOCAL_USER_ID=local-dev

# ── Optional: Tavily (web_search tool) ───────────────────────────────────────
# Required if you use the web_search tool via the ToolServer.
TAVILY_API_KEY=

# ── Optional: Resend (send_email tool) ────────────────────────────────────────
# Used by toolserver/tools/send_email.py
RESEND_API_KEY=
